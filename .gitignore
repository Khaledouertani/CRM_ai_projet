# =============================================================================
# CRM AI Project - .gitignore
# =============================================================================
# This file specifies intentionally untracked files that Git should ignore.
# Files listed here will not be tracked or committed to the repository.
# =============================================================================

# ------------------------- Python Cache & Byte Code -------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
*.whl
pip-log.txt
pip-delete-this-directory.txt

# ------------------------- Virtual Environments -------------------------------
venv/
ENV/
env/
.venv/
venv*/
env/*

# ------------------------- Environment Variables ------------------------------
.env
.env.local
.env.*.local
# NOTE: Contains sensitive credentials, API keys, and database passwords
# If you want to share .env template, create .env.example

# ------------------------- Database Files ---------------------------------
crm.db
*.sqlite
*.sqlite3
*.db
*.db-journal

# ------------------------- RAG Vector Database ----------------------------
rag_db/
chroma.sqlite3
.vectorstore/
vectors/

# ------------------------- Audio Files ------------------------------------
audio/
*.mp3
*.wav
*.m4a
*.ogg
*.flac
*.aac
*.mpeg
*.mp4

# ------------------------- Streamlit Cache --------------------------------
.streamlit/
.streamlit/config.toml
.streamlit/credentials.toml
.streamlit/.cache/

# ------------------------- IDE & Editor -----------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.user
*.userprefs

# ------------------------- Logs & Temporary -----------------------------
*.log
*.tmp
*.temp
logs/
tmp/
temp/

# ------------------------- Test Files ------------------------------------
.pytest_cache/
.coverage
htmlcov/
*.cover

# ------------------------- Build & Distribution -------------------------
dist/
build/
*.egg-info/
.pyinstaller/
__build__/

# ------------------------- Jupyter Notebook -----------------------------
.ipynb_checkpoints/
*.ipynb
.ipynb_checkpoints

# ------------------------- Model Files (if downloaded) -----------------
models/
*.bin
*.h5
*.onnx
*.pkl

# ------------------------- Sensitive Data -------------------------------
credentials.json
secrets.yaml
*password*
*secret*
*.key

# ------------------------- OS Generated Files ---------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------- Project Specific Data -----------------------
rapport_agents.csv
*.csv
*.xlsx
gap_analysis.md

# ------------------------- Cache & Temporary Data ----------------------
.cache/
*.cache
#-------------------------------- ai Agent ----------------------------------
agent.md
.opencode/
node_modules

# .NET build artifacts
BackendDotNet/**/bin/
BackendDotNet/**/obj/
