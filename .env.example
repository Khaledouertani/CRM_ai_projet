# =============================================================================
# CRM AI Project - Environment Variables Example
# =============================================================================
# Copier ce fichier vers .env et remplacer les valeurs
#   cp .env.example .env
#
# Toutes les variables REQUISES doivent avoir une valeur.
# Les variables optionnelles ont une valeur par defaut (notee apres :-).
# =============================================================================

# ------------------------- JWT Authentication (REQUIS) -----------------------
# Cle secrete pour signer les tokens JWT (minimum 32 caracteres, recommande 64+)
# Generer une cle: openssl rand -base64 64
JWT_SECRET=changer_ici_une_cle_secrete_longue_et_aleatoire

# Optionnels - valeurs par defaut ci-dessous
# JWT_ISSUER=CrmApi
# JWT_AUDIENCE=CrmApp

# ------------------------- PostgreSQL (REQUIS) -------------------------------
# Identifiants de la base de donnees PostgreSQL
DB_USER=postgres
DB_PASSWORD=changer_ici_mot_de_passe
DB_NAME=pfe_crm_ia

# ------------------------- Port (optionnel) ----------------------------------
# Port d'ecoute du frontend (defaut: 80)
# PORT=80

# ------------------------- Ollama AI (optionnel) ------------------------------
# URL du service Ollama (commentee = desactivee)
# OLLAMA_URL=http://host.docker.internal:11434
