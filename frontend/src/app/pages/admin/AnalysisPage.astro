import React, { useState } from 'react';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Badge } from '@/components/ui/badge';
import { Progress } from '@/components/ui/progress';
import { ScrollArea } from '@/components/ui/scroll-area';
import { 
  Mic, FileAudio, Send, Loader2, User, Bot, 
  TrendingUp, TrendingDown, Minus,
  AlertCircle, CheckCircle, Clock, MessageSquare
} from 'lucide-react';

interface AnalysisResult {
  transcription: string;
  labeledTranscript: string;
  sentiment: 'POSITIVE' | 'NEGATIVE' | 'NEUTRAL';
  sentimentScore: number;
  summary: string;
  keywords: string[];
  scores: { ecoute: number; persuasion: number; empathie: number; argumentation: number; refus: number; vente: number };
  finalScore: number;
  performance: string;
  customerIntent: string;
  appointmentDate: string;
  appointmentConfidence: number;
  postalCode: string;
  refusalReason: string;
  nextSteps: string;
  agentTalkRatio: number;
  clientTalkRatio: number;
  inactivityDetected: boolean;
}

export default function AnalysisPage() {
  const [file, setFile] = useState<File | null>(null);
  const [analyzing, setAnalyzing] = useState(false);
  const [result, setResult] = useState<AnalysisResult | null>(null);
  const [dragActive, setDragActive] = useState(false);
  const [activeTab, setActiveTab] = useState('transcript');

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault();
    setDragActive(false);
    if (e.dataTransfer.files && e.dataTransfer.files[0]) {
      const f = e.dataTransfer.files[0];
      if (f.type.startsWith('audio/') || f.name.endsWith('.mp3') || f.name.endsWith('.wav')) {
        setFile(f);
      }
    }
  };

  const analyzeFile = async () => {
    if (!file) return;
    
    setAnalyzing(true);
    setResult(null);
    
    try {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('agent_name', 'Admin');
      
      const response = await fetch('/api/analyze_turn', {
        method: 'POST',
        body: formData,
      });
      
      if (response.ok) {
        const data = await response.json();
        setResult(data);
      } else {
        throw new Error('Analysis failed');
      }
    } catch (error) {
      console.error('Error:', error);
      // Demo result
      setResult({
        transcription: '[Agent] Bonjour Madame Martin, je suis du Centre de l Énergie...\n[Client] Bonjour, je vous écoute...\n[Agent] Vous avez fait une demande pour les panneaux solaires ?\n[Client] Oui, je voulais connaître le prix...\n[Agent] C est gratuit selon vos revenus. Seriez-vous disponible demain ?',
        labeledTranscript: '[Agent] Bonjour Madame Martin, je suis du Centre de l Énergie.\n[Client] Bonjour, je vous écoute.\n[Agent] Vous avez fait une demande pour les panneaux solaires ?\n[Client] Oui, je voulais connaître le prix.\n[Agent] C est gratuit selon vos revenus. Seriez-vous disponible demain ?',
        sentiment: 'POSITIVE',
        sentimentScore: 0.82,
        summary: 'L agent a contacté Mme Martin pour une rénovation énergétique. Client intéressée, un RDV a été fixé.',
        keywords: ['énergie', 'panneaux solaires', 'rendez-vous', 'aide état'],
        scores: { ecoute: 8, persuasion: 7, empathie: 9, argumentation: 8, refus: 7, vente: 8 },
        finalScore: 78,
        performance: 'Bon',
        customerIntent: 'RDV client 1',
        appointmentDate: 'Demain 14h',
        appointmentConfidence: 85,
        postalCode: '75001',
        refusalReason: '',
        nextSteps: 'Confirmer le rendez-vous par SMS',
        agentTalkRatio: 0.65,
        clientTalkRatio: 0.35,
        inactivityDetected: false,
      });
    } finally {
      setAnalyzing(false);
    }
  };

  const sentimentConfig = {
    POSITIVE: { color: 'text-green-500', bg: 'bg-green-500/10', icon: TrendingUp },
    NEGATIVE: { color: 'text-red-500', bg: 'bg-red-500/10', icon: TrendingDown },
    NEUTRAL: { color: 'text-yellow-500', bg: 'bg-yellow-500/10', icon: Minus },
  };

  return (
    <div className="space-6">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold tracking-tight">Analyse Audio IA</h1>
          <p className="text-muted-foreground">Transcription, sentiment et scoring des appels</p>
        </div>
      </div>

      <div className="grid gap-6 lg:grid-cols-3">
        {/* Upload Panel */}
        <Card className="lg:col-span-1">
          <CardHeader>
            <CardTitle className="flex items-center gap-2">
              <FileAudio className="h-5 w-5" />
              Upload Audio
            </CardTitle>
            <CardDescription>Formats: MP3, WAV, M4A</CardDescription>
          </CardHeader>
          <CardContent>
            <div
              className={`relative rounded-lg border-2 border-dashed p-8 text-center transition-colors ${
                dragActive ? 'border-primary bg-primary/5' : 'border-muted'
              }`}
              onDragEnter={() => setDragActive(true)}
              onDragLeave={() => setDragActive(false)}
              onDragOver={(e) => e.preventDefault()}
              onDrop={handleDrop}
            >
              <input
                type="file"
                accept="audio/*"
                onChange={(e) => setFile(e.target.files?.[0] || null)}
                className="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
              />
              <div className="flex flex-col items-center gap-2">
                <Mic className="h-10 w-10 text-muted-foreground" />
                {file ? (
                  <p className="font-medium">{file.name}</p>
                ) : (
                  <>
                    <p className="font-medium">Glissez un fichier audio ici</p>
                    <p className="text-sm text-muted-foreground">ou cliquez pour sélectionner</p>
                  </>
                )}
              </div>
            </div>
            
            <Button 
              className="w-full mt-4" 
              onClick={analyzeFile}
              disabled={!file || analyzing}
            >
              {analyzing ? (
                <>
                  <Loader2 className="h-4 w-4 mr-2 animate-spin" />
                  Analyse en cours...
                </>
              ) : (
                <>
                  <Send className="h-4 w-4 mr-2" />
                  Analyser
                </>
              )}
            </Button>
          </CardContent>
        </Card>

        {/* Results Panel */}
        <Card className="lg:col-span-2">
          <CardHeader>
            <div className="flex items-center justify-between">
              <CardTitle>Résultats d'analyse</CardTitle>
              {result && (
                <Badge variant={result.performance === 'Excellent' ? 'default' : 'secondary'}>
                  Score: {result.finalScore}%
                </Badge>
              )}
            </div>
          </CardHeader>
          <CardContent>
            {!result ? (
              <div className="flex flex-col items-center justify-center py-12 text-muted-foreground">
                <Mic className="h-12 w-12 mb-4 opacity-50" />
                <p>Upload un fichier audio pour commencer l'analyse</p>
              </div>
            ) : (
              <Tabs value={activeTab} onValueChange={setActiveTab}>
                <TabsList className="grid w-full grid-cols-4">
                  <TabsTrigger value="transcript">Transcription</TabsTrigger>
                  <TabsTrigger value="scores">Scores</TabsTrigger>
                  <TabsTrigger value="sentiment">Sentiment</TabsTrigger>
                  <TabsTrigger value="summary">Résumé</TabsTrigger>
                </TabsList>

                <TabsContent value="transcript" className="mt-4">
                  <ScrollArea className="h-[400px]">
                    <div className="space-y-4">
                      {result.labeledTranscript.split('\n').map((line, i) => {
                        const isAgent = line.includes('[Agent]');
                        return (
                          <div 
                            key={i}
                            className={`flex gap-3 p-3 rounded-lg ${
                              isAgent ? 'bg-primary/5 ml-4' : 'bg-muted mr-4'
                            }`}
                          >
                            {isAgent ? (
                              <Bot className="h-5 w-5 shrink-0 text-primary" />
                            ) : (
                              <User className="h-5 w-5 shrink-0 text-muted-foreground" />
                            )}
                            <p className="text-sm">{line.replace(/^\[(Agent|Client)\]\s/, '')}</p>
                          </div>
                        );
                      })}
                    </div>
                  </ScrollArea>
                  
                  <div className="mt-4 flex items-center gap-4 text-sm">
                    <div className="flex items-center gap-2">
                      <Progress value={result.agentTalkRatio * 100} className="h-2 w-24" />
                      <span className="text-muted-foreground">Agent: {Math.round(result.agentTalkRatio * 100)}%</span>
                    </div>
                    <div className="flex items-center gap-2">
                      <Progress value={result.clientTalkRatio * 100} className="h-2 w-24" />
                      <span className="text-muted-foreground">Client: {Math.round(result.clientTalkRatio * 100)}%</span>
                    </div>
                  </div>
                </TabsContent>

                <TabsContent value="scores" className="mt-4">
                  <div className="space-y-4">
                    {[
                      { label: 'Écoute active', value: result.scores.ecoute, weight: 20 },
                      { label: 'Persuasion', value: result.scores.persuasion, weight: 20 },
                      { label: 'Empathie', value: result.scores.empathie, weight: 15 },
                      { label: 'Argumentation', value: result.scores.argumentation, weight: 15 },
                      { label: 'Gestion des refus', value: result.scores.refus, weight: 15 },
                      { label: 'Conclusion vente', value: result.scores.vente, weight: 15 },
                    ].map((crit) => (
                      <div key={crit.label} className="space-y-1">
                        <div className="flex items-center justify-between text-sm">
                          <span className="flex items-center gap-2">
                            {crit.label}
                            <Badge variant="secondary" className="text-xs">{crit.weight}%</Badge>
                          </span>
                          <span className="font-medium">{crit.value}/10</span>
                        </div>
                        <Progress value={crit.value * 10} className="h-2" />
                      </div>
                    ))}
                    
                    <div className="mt-6 p-4 rounded-lg bg-primary/10">
                      <div className="flex items-center justify-between">
                        <span className="font-bold">Score Final</span>
                        <div className="text-right">
                          <p className="text-2xl font-bold">{result.finalScore}%</p>
                          <Badge variant={result.performance === 'Excellent' ? 'default' : 'secondary'}>
                            {result.performance}
                          </Badge>
                        </div>
                      </div>
                    </div>
                  </div>
                </TabsContent>

                <TabsContent value="sentiment" className="mt-4">
                  <div className="space-y-6">
                    <div className={`flex items-center gap-4 p-4 rounded-lg ${sentimentConfig[result.sentiment].bg}`}>
                      {React.createElement(sentimentConfig[result.sentiment].icon, { 
                        className: `h-12 w-12 ${sentimentConfig[result.sentiment].color}` 
                      })}
                      <div>
                        <p className={`text-2xl font-bold ${sentimentConfig[result.sentiment].color}`}>
                          {result.sentiment}
                        </p>
                        <p className="text-sm text-muted-foreground">
                          Confiance: {Math.round(result.sentimentScore * 100)}%
                        </p>
                      </div>
                    </div>
                    
                    <div>
                      <h4 className="font-medium mb-2">Mots-clés détectés</h4>
                      <div className="flex flex-wrap gap-2">
                        {result.keywords.map((kw) => (
                          <Badge key={kw} variant="outline">{kw}</Badge>
                        ))}
                      </div>
                    </div>
                    
                    <div className="grid grid-cols-2 gap-4">
                      <div className="p-3 rounded-lg bg-muted">
                        <p className="text-sm text-muted-foreground">Intention client</p>
                        <p className="font-medium">{result.customerIntent}</p>
                      </div>
                      <div className="p-3 rounded-lg bg-muted">
                        <p className="text-sm text-muted-foreground">Motif de refus</p>
                        <p className="font-medium">{result.refusalReason || 'N/A'}</p>
                      </div>
                    </div>
                  </div>
                </TabsContent>

                <TabsContent value="summary" className="mt-4">
                  <div className="space-y-4">
                    <Card>
                      <CardHeader className="pb-2">
                        <CardTitle className="text-base">Résumé de l'appel</CardTitle>
                      </CardHeader>
                      <CardContent>
                        <p className="text-sm">{result.summary}</p>
                      </CardContent>
                    </Card>
                    
                    <Card>
                      <CardHeader className="pb-2">
                        <CardTitle className="text-base flex items-center gap-2">
                          <Clock className="h-4 w-4" />
                          Rendez-vous détecté
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <div className="flex items-center justify-between">
                          <div>
                            <p className="font-medium">{result.appointmentDate || 'Non détecté'}</p>
                            <p className="text-sm text-muted-foreground">
                              Confiance: {result.appointmentConfidence}%
                            </p>
                          </div>
                          {result.appointmentConfidence >= 70 && (
                            <Button size="sm">
                              <CheckCircle className="h-4 w-4 mr-2" />
                              Confirmer RDV
                            </Button>
                          )}
                        </div>
                      </CardContent>
                    </Card>
                    
                    <Card>
                      <CardHeader className="pb-2">
                        <CardTitle className="text-base flex items-center gap-2">
                          <MessageSquare className="h-4 w-4" />
                          Prochaines actions
                        </CardTitle>
                      </CardHeader>
                      <CardContent>
                        <p className="text-sm">{result.nextSteps}</p>
                      </CardContent>
                    </Card>
                    
                    <div className="grid grid-cols-2 gap-4">
                      <div className="p-3 rounded-lg bg-muted">
                        <p className="text-sm text-muted-foreground">Code postal</p>
                        <p className="font-medium">{result.postalCode || 'Non détecté'}</p>
                      </div>
                      <div className="p-3 rounded-lg bg-muted">
                        <p className="text-sm text-muted-foreground">Inactivité</p>
                        <div className="flex items-center gap-2">
                          {result.inactivityDetected ? (
                            <AlertCircle className="h-4 w-4 text-warning" />
                          ) : (
                            <CheckCircle className="h-4 w-4 text-green-500" />
                          )}
                          <p className="font-medium">
                            {result.inactivityDetected ? 'Détectée' : 'Aucune'}
                          </p>
                        </div>
                      </div>
                    </div>
                  </div>
                </TabsContent>
              </Tabs>
            )}
          </CardContent>
        </Card>
      </div>
    </div>
  );
}