import React, { useState, useEffect } from 'react';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/aui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Slider } from '@/components/aui/slider';
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from '@/components/ui/table';
import { Progress } from '@/components/aui/progress';
import {
  Target, Bell, Users, Clock, AlertTriangle,
  Save, RefreshCw, CheckCircle, XCircle
} from 'lucide-react';
interface Weights { ecoute: number; persuasion: number; empathie: number; argumentation: number; refus: number; vente: number; }
interface AlertConfig { min_ score: number; max_ inactivity_ minutes: number; min_ conversion_ rate: number; alert_ email: string; alert_ enabled: boolean; }
interface AgentScore { id: number; name: string; score: number; qualification: string; ref us_ reason: string; }
const criteriaLabels: Record<keyof Weights, string> = {
  ecoute: 'Écoute active', persuasion: 'Persuasion', empathie: 'Empathie',
  argumentation: 'Argumentation', refus: 'Gestion des refus', vente: 'Conclusion de la vente'
};
export default function ScoringPage() {
  const [weights, setWeights] = useState<Weights>({ ecoute: 20, persuasion: 20, empathie: 15, argumentation: 15, refus: 15, vente: 15 });
  const [alerts, setAlerts] = useState<AlertConfig>({ min_score: 70, max_inactivity_minutes: 15, min_conversion_rate: 40, alert_email: 'admin@crm.local', alert_enabled: true });
  const [totalWeight, setTotalWeight] = useState(100);
  const [saving, setSaving] = useState(false);
  const [saveMsg, setSaveMsg] = useState('');
  const [agents, setAgents] = useState<AgentScore[]>([]);
  useEffect(() => { setTotalWeight(Object.values(weights).reduce((a, b) => a + b, 0)); }, [weights]);
  useEffect(() => { fetchData(); }, []);
  const fetchData = async () => {
    try { const [cfgRes, agentRes] = await Promise.all([fetch('/api/config'), fetch('/api/analytics/agents- performance')]);
      if (cfgRes.ok) { const cfg = await cfgRes.json(); if (cfg.weights) setWeights(cfg.weights); if (cfg.alerts) setAlerts(cfg.alerts); }
      if (agentRes.ok) { const data = await agentRes.json(); setAgents(data.agents || []); }
    } catch (error) { setAgents([{ id: 1, name: 'Sana', score: 92, qualification: 'RDV client 1', ref us_reason: '' }, { id: 2, name: 'Ali', score: 88, qualification: 'RDV client 2', ref us_reason: '' }, { id: 3, name: 'Omar', score: 75, qualification: 'Refus', ref us_reason: 'prix_ trop_eleve' }]); }
  };
  const handleSave = async () => {
    if (totalWeight !== 100) { setSaveMsg('La somme doit être = 100%'); return; }
    setSaving(true);
    try { const res = await fetch('/api/config/weights', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ weights, alerts }) });
      setSaveMsg(res.ok ? 'Enregistré !' : 'Erreur'); } catch { setSaveMsg('Erreur'); } finally { setSaving(false); }
  };
  return (
    <div className="space- y-6">
      <div className="flex items- center justify- between"> <h1 className="text-2xl font-bold">Configuration Scoring</h1> </div>
      <div className="grid gap-6 lg:grid-cols-2">
        <Card> <CardHeader> <CardTitle> Pondérations critères </CardTitle> <CardDescription> Somme: <span className={totalWeight === 100 ? 'text-green' : 'text-red'}>{totalWeight}%</span> </CardDescription> </CardHeader> <CardContent className="space- y-4">
          {(Object.keys(weights) as Array<keyof Weights>).map(key => ( <div key={key} className="space- y-2"> <div className="flex justify-between"> <label>{criteriaLabels[key]}</label> <span className="font-medium">{weights[key]}%</span> </div> <Slider value={[weights[key]]} min={0} max={100} step={5} onValueChange={v => setWeights(p => ({ ...p, [key]: v[0] }))} /> </div> ))}
        </CardContent> </Card>
        <Card> <CardHeader> <CardTitle> Alertes seuil </CardTitle> <CardDescription> Notifications automatiques </CardDescription> </CardHeader> <CardContent className="space- y-4">
          <div className="flex items-center gap-4"> <Target className="h-4 w-4" /> <label>Score minimum (%)</label> <input type="number" value={alerts.min_score} onChange={e => setAlerts(p => ({ ...p, min_score: +e.target.value }))} className="w-20" /> </div>
          <div className="flex items-center gap-4"> <Clock className="h-4 w-4" /> <label>Inactivité max (min)</label> <input type="number" value={alerts.max_inactivity_minutes} onChange={e => setAlerts(p => ({ ...p, max_inactivity_minutes: +e.target.value }))} className="w-20" /> </div>
          <div className="flex items-center gap-4"> <Users className="h-4 w-4" /> <label>Conversion min (%)</label> <input type="number" value={alerts.min_conversion_rate} onChange={e => setAlerts(p => ({ ...p, min_conversion_rate: +e.target.value }))} className="w-20" /> </div>
          <div className="flex items-center gap-4"> <Bell className="h-4 w-4" /> <label>Email notification</label> <input type="email" value={alerts.alert_email} onChange={e => setAlerts(p => ({ ...p, alert_email: e.target.value }))} className="flex-1" /> </div>
          <div className="flex items-center gap-2"> <input type="checkbox" checked={alerts.alert_enabled} onChange={e => setAlerts(p => ({ ...p, alert_enabled: e.target.checked }))} /> <label>Activer les alertes</label> </div>
        </CardContent> </Card>
      </div>
      <Button onClick={handleSave} disabled={saving || totalWeight !== 100}> <Save className="h-4 w-4 mr-2" /> {saving ? 'Enregistrement...' : 'Enregistrer'} </Button>
      {saveMsg && <span className={saveMsg.includes('succès') ? 'text-green' : 'text-red'}>{saveMsg}</span>}
      <Card> <CardHeader> <CardTitle> Performance agents </CardTitle> </CardHeader> <CardContent> <Table> <TableHeader> <TableRow><TableHead>Agent</TableHead><TableHead>Score</TableHead><TableHead>Qualification</TableHead><TableHead>Motif refus</TableHead><TableHead>Status</TableHead></TableRow> </TableHeader> <TableBody> {agents.map(a => ( <TableRow key={a.id}> <TableCell>{a.name}</TableCell> <TableCell><Progress value={a.score} className="h-2 w-24" /><span>{a.score}%</span></TableCell> <TableCell><Badge>{a.qualification}</Badge></TableCell> <TableCell><Badge variant="destructive">{a.ref us_reason || 'N/A'}</Badge></TableCell> <TableCell>{a.score >= alerts.min_score ? <CheckCircle className="h-4 w-4 text-green" /> : <XCircle className="h-4 w-4 text-red" />}</TableCell> </TableRow> ))} </TableBody> </Table> </CardContent> </Card>
    </div>
  );
}