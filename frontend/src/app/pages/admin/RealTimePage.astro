import React, { useState, useEffect } from 'react';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Progress } from '@/components/ui/progress';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import {
  Activity, Users, Clock, AlertTriangle, Phone,
  RefreshCw, Play, Pause, Circle, Wifi, WifiOff
} from 'lucide-react';
interface AgentLive { id: number; name: string; status: 'active' | 'inactive' | 'break'; calls: number; idleTime: number; firstCall: string; lastCall: string; }
interface HourlyData { hour: number; calls: number; avgScore: number; peak: boolean; }
export default function RealTimePage() {
  const [loading, setLoading] = useState(true);
  const [agents, setAgents] = useState<AgentLive[]>([]);
  const [hourlyData, setHourlyData] = useState<HourlyData[]>([]);
  const [alerts, setAlerts] = useState<any[]>([]);
  const [lastUpdate, setLastUpdate] = useState(new Date());
  useEffect(() => { fetchData(); }, []);
  useEffect(() => {
    const interval = setInterval(() => { fetchData(); setLastUpdate(new Date()); }, 30000);
    return () => clearInterval(interval);
  }, []);
  const fetchData = async () => {
    setLoading(true);
    try {
      const [pointageRes, analyticsRes, alertsRes] = await Promise.all([
        fetch('/api/analytics/pointage'),
        fetch('/api/analytics/overview'),
        fetch('/api/alerts/ history')
      ]);
      if (pointageRes.ok) setAgents(await pointageRes.json());
      if (analyticsRes.ok) {
        const data = await analyticsRes.json();
        setHourlyData(data.hourlyData || generateHourlyDemo());
      }
      if (alertsRes.ok) setAlerts((await alertsRes.json()).history || []);
    } catch {
      setAgents(generateAgentDemo());
      setHourlyData(generateHourlyDemo());
    } finally { setLoading(false); }
  };
  const generateAgentDemo = (): AgentLive[] => [
    { id: 1, name: 'Sana', status: 'active', calls: 12, idleTime: 0, firstCall: '09:15', lastCall: '17:32' },
    { id: 2, name: 'Ali', status: 'active', calls: 10, idleTime: 0, firstCall: '09:22', lastCall: '17:28' },
    { id: 3, name: 'Omar', status: 'inactive', calls: 8, idleTime: 18, firstCall: '09:30', lastCall: '16:45' },
    { id: 4, name: 'Mariam', status: 'break', calls: 6, idleTime: 0, firstCall: '10:00', lastCall: '15:20' },
    { id: 5, name: 'Youssef', status: 'active', calls: 9, idleTime: 0, firstCall: '09:18', lastCall: '17:25' },
  ];
  const generateHourlyDemo = (): HourlyData[] => {
    const data: HourlyData[] = [];
    for (let h = 9; h <= 18; h++) {
      const calls = Math.floor(Math.random() * 15) + 5;
      data.push({ hour: h, calls, avgScore: Math.floor(Math.random() * 20) + 70, peak: calls > 12 });
    }
    return data;
  };
  const statusConfig = {
    active: { color: 'text-green-500', bg: 'bg-green-500/10', icon: Circle, label: 'Actif' },
    inactive: { color: 'text-red-500', bg: 'bg-red-500/10', icon: AlertTriangle, label: 'Inactif' },
    break: { color: 'text-yellow-500', bg: 'bg-yellow-500/10', icon: Pause, label: 'Pause' },
  };
  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold tracking-tight">Temps Réel</h1>
          <p className="text- muted-foreground">Monitoring agents et productivité</p>        </div>
        <div className="flex items-center gap-4">
          <span className="text-sm text- muted-foreground">MAJ: {lastUpdate.toLocaleTimeString()}</span>
          <Button variant="outline" size="sm" onClick={fetchData}>
            <RefreshCw className="h-4 w-4 mr-2" /> Actualiser          </Button>
        </div>
      </div>

      {/* Agent Status Grid */}
      <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
        {agents.map(agent => {
          const cfg = statusConfig[agent.status];
          return (
            <Card key={agent.id} className={agent.status === 'inactive' ? 'border-destructive' : ''}>
              <CardHeader className="pb-2">
                <div className="flex items-center justify-between">
                  <span className="font-medium">{agent.name}</span>
                  <Badge variant={agent.status === 'active' ? 'default' : 'secondary'}>
                    {cfg.label}
                  </Badge>                </div>
              </CardHeader>
              <CardContent className="space-y-2">
                <div className="flex items-center gap-2">
                  <cfg.icon className={`h-4 w-4 ${cfg.color}`} />
                  <span className="text-2xl font-bold">{agent.calls}</span>
                  <span className="text-sm text- muted-foreground">appels</span>
                </div>
                {agent.status === 'inactive' && (
                  <div className="text-sm text-destructive">
                    Inactif: {agent.idleTime} min                  </div>
                )}
                <div className="flex justify-between text-xs text- muted-foreground">
                  <span>1er: {agent.firstCall}</span>
                  <span>Dernier: {agent.lastCall}</span>
                </div>
              </CardContent>
            </Card>
          );
        })}
      </div>

      {/* Alerts + Hourly Analysis */}
      <Tabs defaultValue="alerts">
        <TabsList>
          <TabsTrigger value="alerts">Alertes ({alerts.length})</TabsTrigger>
          <TabsTrigger value="hourly">Heures pointe</TabsTrigger>        </TabsList>

        <TabsContent value="alerts" className="mt-4">
          {alerts.length === 0 ? (
            <Card><CardContent className="py-8 text-center text- muted-foreground">
              <Activity className="h-8 w-8 mx-auto mb-2 opacity-50" />
              <p>Aucune alerte</p>            </CardContent></Card>
          ) : (
            <div className="space-y-2">
              {alerts.map((alert, i) => (
                <Card key={i}><CardContent className="flex items-center justify-between py-3">
                  <div className="flex items-center gap-3">
                    <AlertTriangle className="h-4 w-4 text-destructive" />
                    <div>
                      <p className="font-medium">{alert.message || alert.alert_type}</p>
                      <p className="text-xs text- muted-foreground">{new Date(alert.created_at).toLocaleString()}</p>
                    </div>
                  </div>
                  <Button size="sm" variant="ghost">Ignorer</Button>
                </CardContent></Card>
              ))}
            </div>
          )}
        </TabsContent>

        <TabsContent value="hourly" className="mt-4">
          <Card>
            <CardHeader>
              <CardTitle>Analyse des heures creuses/pointe</CardTitle>
              <CardDescription>Volumes d'appels par heure</CardDescription>            </CardHeader>
            <CardContent>
              <div className="grid grid-cols-10 gap-1">
                {hourlyData.map(h => (
                  <div key={h.hour} className="text-center">
                    <div className={`text-2xl font-bold ${h.peak ? 'text-green-500' : 'text- muted-foreground'}`}>
                      {h.calls}
                    </div>                    <div className="text-xs text- muted-foreground">{h.hour}h</div>
                    {h.peak && <div className="text-xs text-green-500">Pointe</div>}
                    <Progress value={(h.calls / 15) * 100} className="h-16 mt-1" />
                  </div>
                ))}
              </div>            </CardContent>          </Card>
        </TabsContent>      </Tabs>
    </div>
  );
}