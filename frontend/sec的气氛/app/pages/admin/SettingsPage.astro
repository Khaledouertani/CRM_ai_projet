import React, { useState, useEffect } from 'react';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/aui/card';
import { Badge } from '@/components/aui/badge';
import { Button } from '@/components/aui/button';
import { Input } from '@/components/aui/input';
import { Switch } from '@/components/aui/switch';
import { Separator } from '@/components/aui/separator';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/aui/tabs';
import {
  Settings, Cpu, Mic, Database, Shield, User, Users, Bell, Save,
  CheckCircle, XCircle, Eye, EyeOff, AlertTriangle, Lock, FileText
} from 'lucide-react';
interface SystemConfig { whisperModel: string; ollamaModel: string; diarizationEnabled: boolean; hfToken: string; }interface RGPDConfig { anonymizeTranscripts: boolean; autoDeleteDays: number; logRetentionDays: number; encryptionEnabled: boolean; }interface User { id: number; name: string; role: string; email: string; active: boolean; }
export default function SettingsPage() {  const [system, setSystem] = useState<SystemConfig>({ whisperModel: 'tiny', ollamaModel: 'gemma3:4b', diarizationEnabled: true, hfToken: '' });  const [rgpd, setRgpd] = useState<RGPDConfig>({ anonymizeTranscripts: true, autoDeleteDays: 90, logRetentionDays: 365, encryptionEnabled: true });  const [users, setUsers] = useState<User[]>([]);  const [saving, setSaving] = useState(false);  const [saveMsg, setSaveMsg] = useState('');  const [showToken, setShowToken] = useState(false);  useEffect(() => { fetchConfig(); }, []);  const fetchConfig = async () => {    try {      const res = await fetch('/api/config');      if (res.ok) { const cfg = await res.json(); if (cfg.system) setSystem(cfg.system); if (cfg.rgpd) setRgpd(cfg.rgpd); }      const usersRes = await fetch('/auth/agents');      if (usersRes.ok) setUsers(await usersRes.json());    } catch {      setUsers([{ id: 1, name: 'Admin', role: 'admin', email: 'admin@local', active: true }, { id: 2, name: 'Sana Agent', role: 'agent', email: 'sana@local', active: true }]); }  };  const handleSave = async () => {    setSaving(true);    try { const res = await fetch('/api/ config/weights', { method: 'PUT', headers: { 'Content-Type': 'application/ json' }, body: JSON.stringify({ system, rgpd }) }); setSaveMsg(res.ok ? 'Configuration enregistrée !' : 'Erreur'); } catch { setSaveMsg('Erreur'); } finally { setSaving(false); }  };  return (    <div className="space-y-6">      <div className="flex items-center justify- between">        <div>          <h1 className="text-2xl font-bold tracking-tight">Paramètres</h1>          <p className="text- muted-foreground">Configuration système et conformité RGPD</p>        </div>        <Button onClick={handleSave} disabled={saving}>          <Save className="h-4 w-4 mr-2" /> {saving ? 'Enregistrement...' : 'Enregistrer'}        </Button>      </div>      <Tabs defaultValue="system">        <TabsList>          <TabsTrigger value="system">Système IA</TabsTrigger>          <TabsTrigger value="rgpd">RGPD</TabsTrigger>          <TabsTrigger value="users">Utilisateurs</TabsTrigger>        </TabsList>        <TabsContent value="system" className="mt-4">          <div className="grid gap-6 lg:grid-cols-2">            <Card>              <CardHeader>                <CardTitle className="flex items-center gap-2"><Mic className="h-5 w-5" />Transcription audio</CardTitle>                <CardDescription>Configuration Whisper</CardDescription>              </CardHeader>              <CardContent className="space-y-4">                <div className="space-y-2">                  <label className="text-sm font-medium">Modèle Whisper</label>                  <select value={system.whisperModel} onChange={e => setSystem(p => ({ ...p, whisperModel: e.target.value }))} className="w-full h-10 rounded-md border border-input bg-background px-3">                    <option value="tiny">Tiny (rapide)</option>                    <option value="base">Base</option>                    <option value="small">Small</option>                    <option value="medium">Medium</option>                  </select>                </div>                <div className="flex items-center justify-between">                  <div>                    <p className="font-medium">Diarization (Agent/Client)</p>                    <p className="text-sm text- muted-foreground">Identification des locuteurs via pyannote</p>                  </div>                  <Switch checked={system.diarizationEnabled} onCheckedChange={v => setSystem(p => ({ ...p, diarizationEnabled: v }))} />                </div>              </CardContent>            </Card>            <Card>              <CardHeader>                <CardTitle className="flex items-center gap-2"><Cpu className="h-5 w-5" />LLM (Ollama)</CardTitle>                <CardDescription>Configuration modèle de langage</CardDescription>              </CardHeader>              <CardContent className="space-y-4">                <div className="space-y-2">                  <label className="text-sm font-medium">Modèle Ollama</label>                  <select value={system.ollamaModel} onChange={e => setSystem(p => ({ ...p, ollamaModel: e.target.value }))} className="w-full h-10 rounded-md border border-input bg-background px-3">                    <option value="gemma3:4b">Gemma 3 (4B)</option>                    <option value="llama3">Llama 3</option>                    <option value="mistral">Mistral</option>                    <option value="phi3">Phi-3</option>                  </select>                </div>                <div className="space-y-2">                  <label className="text-sm font-medium">Token HuggingFace (pyannote)</label>                  <div className="relative">                    <Input type={showToken ? 'text' : 'password'} value={system.hfToken} onChange={e => setSystem(p => ({ ...p, hfToken: e.target.value }))} placeholder="hf_xxxx" className="pr-10" />                    <button type="button" onClick={() => setShowToken(!showToken)} className="absolute right-3 top-1/2 -translate-y-1/2">                      {showToken ? <EyeOff className="h-4 w-4" /> : <Eye className="h-4 w-4" />}                    </button>                  </div>                </div>              </CardContent>            </Card>          </div>        </TabsContent>        <TabsContent value="rgpd" className="mt-4">          <Card>            <CardHeader>              <CardTitle className="flex items-center gap-2"><Shield className="h-5 w-5" />Conformité RGPD</CardTitle>              <CardDescription>Gestion des données personnelles</CardDescription>            </CardHeader>            <CardContent className="space-y-6">              <div className="flex items-center justify-between">                <div>                  <p className="font-medium">Anonymisation des transcriptions</p>                  <p className="text-sm text- muted-foreground">Masquer noms et coordonnées dans les enregistrements</p>                </div>                <Switch checked={rgpd.anonymizeTranscripts} onCheckedChange={v => setRgpd(p => ({ ...p, anonymizeTranscripts: v }))} />              </div>              <Separator />              <div className="flex items-center justify-between">                <div>                  <p className="font-medium">Chiffrement des données</p>                  <p className="text-sm text- muted-foreground">Protection des données sensibles</p>                </div>                <Switch checked={rgpd.encryptionEnabled} onCheckedChange={v => setRgpd(p => ({ ...p, encryptionEnabled: v }))} />              </div>              <Separator />              <div className="grid gap-4 sm:grid-cols-2">                <div className="space-y-2">                  <label className="text-sm font-medium">Conservation données (jours)</label>                  <Input type="number" value={rgpd.autoDeleteDays} onChange={e => setRgpd(p => ({ ...p, autoDeleteDays: +e.target.value }))} />                </div>                <div className="space-y-2">                  <label className="text-sm font-medium">Conservation logs (jours)</label>                  <Input type="number" value={rgpd.logRetentionDays} onChange={e => setRgpd(p => ({ ...p, logRetentionDays: +e.target.value }))} />                </div>              </div>            </CardContent>          </Card>        </TabsContent>        <TabsContent value="users" className="mt-4">          <Card>            <CardHeader>              <CardTitle className="flex items-center gap-2"><Users className="h-5 w-5" />Gestion des utilisateurs</CardTitle>              <CardDescription>Droits d'accès et rôles</CardDescription>            </CardHeader>            <CardContent>              <div className="space-y-4">                {users. map(user => (                  <div key={user.id} className="flex items-center justify-between p-4 rounded-lg bg-muted">                    <div className="flex items-center gap-3">                      <div className="h-10 w-10 rounded-full bg- primary flex items-center justify-center text-primary-foreground font-medium">                        {user.name.charAt(0)}                      </div>                      <div>                        <p className="font-medium">{user.name}</p>                        <p className="text-sm text- muted-foreground">{user.email}</p>                      </div>                    </div>                    <div className="flex items-center gap-2">                      <Badge variant={user.role === 'admin' ? 'default' : 'secondary'}>{user.role}</Badge>                      <Badge variant={user.active ? 'default' : 'destructive'}>{user.active ? 'Actif' : 'Inactif'}</Badge>                      <Button size="sm" variant="ghost">Modifier</Button>                    </div>                  </div>                ))}                <Button variant="outline" className="w-full">                  <User className="h-4 w-4 mr-2" /> Ajouter un utilisateur                </Button>              </div>            </CardContent>          </Card>        </TabsContent>      </Tabs>      {saveMsg && <p className={saveMsg. includes('succès') ? 'text-green' : 'text-red'}>{saveMsg}</p>}    </div>  );
}